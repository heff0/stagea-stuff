# Stagea shell — environment variables.
# Copy to .env and fill in. .env is gitignored.

# Public site name used in headings and meta tags.
PUBLIC_SITE_NAME=Stagea

# --- Reserved for future features (commented out until the underlying ---
# --- services exist; the schema is declared in astro.config.mjs). ----

