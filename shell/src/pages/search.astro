---
import Layout from "~/layouts/Layout.astro";
---

<Layout
  title="Search — Stagea"
  description="Federated search across the Stagea forum, wiki, blog and shop. Not yet available."
>
  <section class="py-16">
    <h1 class="text-3xl font-bold tracking-tight">Search</h1>
    <p class="mt-3 max-w-2xl text-(--color-muted)">
      Federated search across forum threads, wiki pages, blog posts and parts.
      Endpoint to be wired into the planned <code>SEARCH_API_URL</code>{' '}
      (see <code>astro.config.mjs</code>) once the indexer service lands.
    </p>

    <div
      class="mt-10 rounded-xl border border-dashed border-(--color-border) bg-(--color-surface)/30 p-10 text-center text-sm text-(--color-muted)"
    >
      Not implemented yet. Track progress at{' '}
      <a
        class="text-(--color-accent) underline-offset-4 hover:underline"
        href="https://github.com/heff0/stagea-stuff"
      >
        github.com/heff0/stagea-stuff
      </a>.
    </div>
  </section>
</Layout>
