---
import Layout from "~/layouts/Layout.astro";

const services = [
  {
    name: "Forum",
    badge: "NodeBB",
    href: "http://localhost:4567/",
    description:
      "Talk to other Stagea owners. Build threads, share fixes, ask questions.",
  },
  {
    name: "Wiki",
    badge: "MediaWiki",
    href: "http://localhost:8080/w/",
    description:
      "Knowledge base of Stagea-specific docs, part numbers, and procedures.",
  },
  {
    name: "Blog",
    badge: "Ghost",
    href: "http://localhost:2368/",
    description: "Editorial features and community newsletters.",
  },
  {
    name: "Shop",
    badge: "Saleor",
    href: "http://localhost:3000/",
    description: "Curated parts and merch, fulfilled through Saleor.",
  },
];
---

<Layout>
  <section class="py-16">
    <p class="text-sm font-semibold uppercase tracking-widest text-(--color-accent)">
      Nissan Stagea community
    </p>
    <h1 class="mt-3 text-5xl font-bold tracking-tight md:text-6xl">
      Stagea, in one place.
    </h1>
    <p class="mt-5 max-w-2xl text-lg text-(--color-muted)">
      Forum, wiki, blog and parts shop &mdash; one account, one community. Built
      by owners, for owners.
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="/account"
        class="inline-flex items-center rounded-md bg-(--color-accent) px-5 py-2.5 text-sm font-semibold text-(--color-bg) transition hover:bg-(--color-accent)/90"
      >
        Sign in
      </a>
      <a
        href="#services"
        class="inline-flex items-center rounded-md border border-(--color-border) px-5 py-2.5 text-sm font-medium text-(--color-text) transition hover:bg-(--color-surface)"
      >
        Browse the stack
      </a>
    </div>
  </section>

  <section id="services" class="scroll-mt-20">
    <h2
      class="mb-6 text-xs font-bold uppercase tracking-widest text-(--color-muted)"
    >
      Services
    </h2>

    <div class="grid gap-4 sm:grid-cols-2">
      {
        services.map((service) => (
          <a
            href={service.href}
            class="group rounded-xl border border-(--color-border) bg-(--color-surface)/60 p-6 transition hover:-translate-y-0.5 hover:border-(--color-accent) hover:bg-(--color-surface-hover)"
          >
            <div class="flex items-center justify-between gap-3">
              <h3 class="text-xl font-semibold">{service.name}</h3>
              <span class="rounded-md bg-(--color-accent-soft) px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-(--color-accent)">
                {service.badge}
              </span>
            </div>
            <p class="mt-2 text-sm leading-relaxed text-(--color-muted)">
              {service.description}
            </p>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
