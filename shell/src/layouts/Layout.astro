---
import "~/styles/global.css";
import Header from "~/components/Header.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Stagea — Nissan Stagea community",
  description = "Forum, wiki, blog and parts shop for Nissan Stagea owners and tuners.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0c0f" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased">
    <Header />
    <main class="mx-auto max-w-6xl px-6 py-12">
      <slot />
    </main>
    <footer
      class="border-t border-(--color-border) py-8 text-center text-sm text-(--color-muted)"
    >
      &copy; Stagea community ·
      <a
        href="https://github.com/heff0/stagea-stuff"
        class="underline-offset-4 hover:text-(--color-text) hover:underline"
      >
        github.com/heff0/stagea-stuff
      </a>
    </footer>
  </body>
</html>
